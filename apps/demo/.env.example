# Solana cluster the demo talks to. Default: devnet
NEXT_PUBLIC_CLUSTER=devnet

# RPC endpoint. For Vercel use your own (Helius, Triton, QuickNode...) — devnet public RPC is rate-limited.
NEXT_PUBLIC_RPC_URL=https://api.devnet.solana.com

# Program ID. Default targets the published localnet/devnet program.
NEXT_PUBLIC_PROGRAM_ID=7M6pdteAnZmj9SEyzjsqUEqfcc4jqhpgLFF9dULDq1iP
