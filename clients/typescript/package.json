{
    "name": "@solana-program/async-vault",
    "version": "0.1.0",
    "description": "TypeScript client for the Async Vault program",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/solana-program/vault.git",
        "directory": "clients/typescript"
    },
    "type": "module",
    "main": "./dist/index.js",
